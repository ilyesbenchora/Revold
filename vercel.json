{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/integrations/hubspot/sync?type=companies",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/integrations/hubspot/sync?type=contacts",
      "schedule": "5 */6 * * *"
    },
    {
      "path": "/api/integrations/hubspot/sync?type=deals",
      "schedule": "10 */6 * * *"
    },
    {
      "path": "/api/cron/compute-kpis",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/detect-risks",
      "schedule": "20 */6 * * *"
    },
    {
      "path": "/api/cron/generate-insights",
      "schedule": "30 6 * * 1"
    }
  ]
}
