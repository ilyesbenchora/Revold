{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/etl-delta",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/etl-full",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/compute-kpis",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/detect-risks",
      "schedule": "20 */6 * * *"
    },
    {
      "path": "/api/cron/compute-fill-rates",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/generate-insights",
      "schedule": "30 6 * * 1"
    },
    {
      "path": "/api/cron/check-alerts",
      "schedule": "35 */6 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 7 * * *"
    }
  ]
}
